" Options
set adblockernotifications=error
set externalcommand=mpv
set searchwords={"yt":"youtube.com/results?search_query=%s", "s":"scholar.google.com/scholar?q=%s", "arch":"wiki.archlinux.org/index.php?search=%s"}
set shell=/bin/bash
set suggestcommands=900
set suggesttopsites=0
set redirecttohttp
set notificationposition="topright"
set vimcommand="st -e vim -c scratch"
set permissioncamera=ask
set guifontsize=20
set permissionmicrophone=ask
set tabclosefocus=previous
set tabreopenposition=previous
set followelement=["url", "onclick", "inputs-click"]
set followlabelposition=insidetopleft
set permissionsallowed=[".*zoom.us.*~mediadevices~microphone~camera"]
set permissionopenexternal=block
colorscheme compact

" Mappings
fmap <C-n> <:set externalcommand=mpv><p.externalLink>
nmap ;n <:set externalcommand=mpv><p.start><startFollowCurrentTab>
nmap t <:tabnew><toExploreMode>
nmap o <toExploreMode><BS>
pmap xx <p.externalLink><toNormalMode>

" Commands
command tabo <:rclose><:lclose>
command tabon <:rclose><:lclose>
command tabonly <:rclose><:lclose>

